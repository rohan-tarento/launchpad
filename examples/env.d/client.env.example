# ~/.config/launchpad/env.d/<slug>.env
# One file per programme. Generated by `launchpad onboard interview`.
# ─────────────────────────────────────────────────────────────────────────────
# 1. Create a GitHub PAT with these scopes:
#      repo, admin:org, project, delete_repo
#    GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# 2. Paste the token below (replace github_pat_REPLACE_ME)
# 3. Save, then:  chmod 600 ~/.config/launchpad/env.d/<slug>.env
#    Source it:   source ~/.config/launchpad/env.d/<slug>.env
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_REPLACE_ME

# GitHub org:  example-org
# Meta repo:   https://github.com/example-org/example-meta

# Clone layout is NOT configured here. Use ~/.config/launchpad/clients.yaml:
#   path:      ~/Workspace/example/example-meta
#   workspace: ~/Workspace/example
