# Copy to ~/.config/launchpad/env.d/<client-id>.env
# Example: env.d/acme.env
#
# Secrets live here — NOT in <client>-meta/.env (gitignored tenant files are optional
# for local overrides only; this file is the machine SSOT for factory tokens).

GITHUB_TOKEN=github_pat_REPLACE_ME

# GitLab forge only:
# GITLAB_TOKEN=glpat-REPLACE_ME

# Optional explicit override (usually set via clients.yaml instead):
# LAUNCHPAD_TENANT_ROOT=~/Workspace/handson/acme/acme-meta
